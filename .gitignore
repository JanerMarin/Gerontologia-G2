__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
*.py[cod]
*$py.class
*.so

# ==================================
# DJANGO
# ==================================
# Base de datos local (cada dev tiene la suya)
db.sqlite3
db_local.sqlite3
*.sqlite3
*.db

# Archivos de media y estáticos
media/
staticfiles/
*.log

# Migraciones locales (comentar si quieres incluir migraciones en el repo)
# */migrations/*.py
# !*/migrations/__init__.py

# ==================================
# CONFIGURACIONES SENSIBLES
# ==================================
# Archivo de variables de entorno (cada desarrollador tiene el suyo)
.env
*.env
!.env.example

# Configuración local de Django (cada desarrollador tiene la suya)
settings_local.py
*/settings_local.py
!settings_local.py.example

# NO ignorar settings.py - ahora es seguro subirlo
# (Las credenciales están en .env)

