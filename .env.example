# ==================================
# CONFIGURACIÓN DE ENTORNO - GERONTOLOGÍA APP
# ==================================
# Copia este archivo como .env y configura tus valores locales
# cp .env.example .env

# ==================================
# DJANGO SETTINGS
# ==================================
SECRET_KEY=django-insecure-CAMBIAR-ESTE-VALOR-POR-UNO-SEGURO
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ==================================
# DATABASE CONFIGURATION
# ==================================
# Opciones: mysql, sqlite3
DB_ENGINE=mysql

# MySQL Configuration
DB_NAME=Gerontologia
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# SQLite Configuration (alternativa para desarrollo)
# Si usas SQLite, cambia DB_ENGINE=sqlite3
# No necesitas configurar DB_NAME, DB_USER, DB_PASSWORD, DB_HOST, DB_PORT

# ==================================
# CONFIGURACIÓN REGIONAL
# ==================================
LANGUAGE_CODE=es-co
TIME_ZONE=America/Bogota

# ==================================
# NOTAS PARA DESARROLLADORES
# ==================================
# 1. Nunca commitear el archivo .env al repositorio
# 2. Cada desarrollador debe tener su propia configuración
# 3. Para producción, usar variables de entorno del servidor
# 4. Generar una nueva SECRET_KEY en: https://djecrety.ir/
